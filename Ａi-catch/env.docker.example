# ========================================
# Docker 環境變數範例
# ========================================
# 使用方式: 複製此檔案為 .env 並修改設定
# cp env.docker.example .env
# ========================================

# 資料庫設定
DB_USER=stockai
DB_PASSWORD=stockai123
DB_NAME=ai_stock_db

# 安全密鑰 (請務必更改!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# 富邦 API 設定 (選填)
FUBON_USER_ID=
FUBON_PASSWORD=
FUBON_CERT_PATH=/app/certs/your-cert.pfx
FUBON_CERT_PASSWORD=

# 通知服務 (選填)
LINE_NOTIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_USERNAME=
EMAIL_PASSWORD=
